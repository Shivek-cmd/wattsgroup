{
  "rewrites": [
    { "source": "/", "destination": "/pages/home/index.html" },
    { "source": "/about", "destination": "/pages/about/index.html" },
    { "source": "/investments", "destination": "/pages/investments/index.html" },
    { "source": "/consulting", "destination": "/pages/consulting/index.html" },
    { "source": "/portfolio", "destination": "/pages/portfolio/index.html" },
    { "source": "/blog", "destination": "/pages/blog/index.html" },
    { "source": "/contact", "destination": "/pages/contact/index.html" },
    { "source": "/privacy-policy", "destination": "/pages/privacy-policy/index.html" },
    { "source": "/terms-of-service", "destination": "/pages/terms-of-service/index.html" },
    { "source": "/blog/ai-automation-small-business", "destination": "/pages/blog/ai-automation-small-business/index.html" },
    { "source": "/blog/canada-dubai-real-estate", "destination": "/pages/blog/canada-dubai-real-estate/index.html" },
    { "source": "/blog/study-abroad-guide-2025", "destination": "/pages/blog/study-abroad-guide-2025/index.html" },
    { "source": "/blog/building-multi-vertical-conglomerate", "destination": "/pages/blog/building-multi-vertical-conglomerate/index.html" },
    { "source": "/blog/ai-content-marketing-future", "destination": "/pages/blog/ai-content-marketing-future/index.html" },
    { "source": "/blog/express-entry-guide", "destination": "/pages/blog/express-entry-guide/index.html" },
    { "source": "/blog/community-driven-business", "destination": "/pages/blog/community-driven-business/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/global/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
